# Copy this file's KEY into the Streamlit Cloud "Secrets" box (Settings → Secrets),
# NOT into the repo. Never commit a real key.
#
# Get a free key at https://console.groq.com  →  API Keys  →  Create API Key
GROQ_API_KEY = "gsk_your_key_here"

# Optional overrides:
# LUMEN_LLM_PROVIDER = "groq"                 # auto-set when GROQ_API_KEY exists
# LUMEN_GROQ_MODEL   = "llama-3.3-70b-versatile"
