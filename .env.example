# Copy to `.env` and adjust. All values are optional — defaults target a fully
# local, free stack (Ollama + HuggingFace + ChromaDB + DuckDuckGo). No API keys.

# --- LLM (Ollama) ---
AGENTRAG_OLLAMA_BASE_URL=http://localhost:11434
AGENTRAG_LLM_MODEL=qwen2.5:3b
AGENTRAG_LLM_TEMPERATURE=0.0

# --- Embeddings (HuggingFace, local) ---
AGENTRAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Retrieval / chunking ---
AGENTRAG_TOP_K=4
AGENTRAG_CHUNK_SIZE=1000
AGENTRAG_CHUNK_OVERLAP=150

# --- Agent ---
AGENTRAG_MAX_AGENT_STEPS=6
AGENTRAG_WEB_RESULTS=4
