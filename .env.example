# Copy to `.env` and adjust. All values are optional — defaults target a fully
# local, free stack (Ollama + HuggingFace + ChromaDB + DuckDuckGo). No API keys.

# --- LLM (Ollama) ---
LUMEN_OLLAMA_BASE_URL=http://localhost:11434
LUMEN_LLM_MODEL=qwen2.5:3b
LUMEN_LLM_TEMPERATURE=0.0

# --- Embeddings (HuggingFace, local) ---
LUMEN_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Retrieval / chunking ---
LUMEN_TOP_K=4
LUMEN_CHUNK_SIZE=1000
LUMEN_CHUNK_OVERLAP=150

# --- Hybrid retrieval (dense vectors + BM25 keyword, fused with RRF) ---
LUMEN_HYBRID_RETRIEVAL=true
LUMEN_HYBRID_DENSE_WEIGHT=0.5
LUMEN_HYBRID_SPARSE_WEIGHT=0.5

# --- Agent ---
LUMEN_MAX_AGENT_STEPS=6
LUMEN_WEB_RESULTS=4
# Self-reflection: grade the answer vs. evidence; retry once if ungrounded.
LUMEN_ENABLE_REFLECTION=true

# --- Conversation memory (persistent, cross-process) ---
LUMEN_MEMORY_DB=data/memory.sqlite
